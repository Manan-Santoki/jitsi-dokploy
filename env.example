# =============================================================================
# Jitsi Meet - Dokploy + Cloudflare Tunnel Configuration
# =============================================================================

# Your Jitsi domain (must match your CF Tunnel public hostname)
JITSI_DOMAIN=meet.yourdomain.com

# Your Hetzner server's PUBLIC IP address
# CRITICAL: This is needed for WebRTC media (UDP) which bypasses CF Tunnel
JVB_ADVERTISE_IPS=YOUR_SERVER_PUBLIC_IP

# Config storage directory
CONFIG=~/.jitsi-meet-cfg

# Timezone
TZ=America/Phoenix

# Jitsi image version
JITSI_IMAGE_VERSION=stable

# JVB UDP port (must be open in firewall)
JVB_PORT=10000

# STUN servers for public IP discovery
JVB_STUN_SERVERS=stun.l.google.com:19302,stun1.l.google.com:19302

# =============================================================================
# Feature toggles
# =============================================================================
ENABLE_AUTH=0
AUTH_TYPE=internal
ENABLE_GUESTS=1
ENABLE_LOBBY=1
ENABLE_PREJOIN_PAGE=1
ENABLE_WELCOME_PAGE=1
ENABLE_BREAKOUT_ROOMS=1
ENABLE_RECORDING=0

# =============================================================================
# Security - passwords (auto-generated by gen-passwords.sh)
# DO NOT REUSE THESE. Run: ./setup.sh to generate.
# =============================================================================
JICOFO_COMPONENT_SECRET=
JICOFO_AUTH_PASSWORD=
JVB_AUTH_PASSWORD=
JIGASI_XMPP_PASSWORD=
JIBRI_RECORDER_PASSWORD=
JIBRI_XMPP_PASSWORD=
